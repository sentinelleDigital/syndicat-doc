{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md",
    "INDEX.md"
  ],
  "provider": {
    "groq": {
      "options": {
        "apiKey": "{env:GROQ_API_KEY}"
      }
    }
  },
  "model": "groq/llama-3.3-70b-versatile",
  "tools": {
    "write": false,
    "edit": false,
    "bash": false,
    "patch": false,
    "webfetch": false,
    "task": false,
    "todowrite": false,
    "todoread": false,
    "list": false
  }
}