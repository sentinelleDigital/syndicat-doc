# Modèle de secrets — COPIE ce fichier en .env puis remplis les vraies valeurs.
#   cp .env.example .env
# Le vrai .env n'est JAMAIS versionné (voir .gitignore) et n'est lu que localement.

# Clés Groq — une par compte (https://console.groq.com/keys)
GROQ_API_KEY_1=gsk_remplace_par_cle_compte_1
GROQ_API_KEY_2=gsk_remplace_par_cle_compte_2

# Mot de passe LOCAL du proxy LiteLLM — tu l'inventes (n'importe quelle chaîne).
LITELLM_MASTER_KEY=sk-syndicat-2026
